# 复制为 .env.development.local（已在 .gitignore，勿提交）
VUE_APP_OPEN_API_BASE_URL=/open-api
VUE_APP_OPEN_API_ADMIN_KEY=your-admin-key-here
# 平台自身管理请求（/internal/admin/**）：填平台网关/平台内网 open-api-service 入口，禁止填 partner-gateway
VUE_APP_OPEN_API_PROXY_TARGET=http://172.16.2.4:35780
# 接入方开放请求（/api/open/v1、/oauth/token）才使用 partner-gateway；管理页面默认不使用
VUE_APP_OPEN_PUBLIC_BASE_URL=http://172.16.2.4:35770
