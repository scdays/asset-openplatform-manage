# 复制为 .env.development.local 并按环境覆盖
VUE_APP_OPEN_API_ADMIN_KEY=dev-internal-admin-key-change-in-prod

# Admin：/open-api-service → 平台网关 7000
# VUE_APP_GATEWAY_PROXY_TARGET=http://172.16.3.32:7000

# Partner：/api/open/v1、/oauth/token → partner-gateway 35770（devServer 反代，模拟第三方）
# VUE_APP_PARTNER_GATEWAY_PROXY_TARGET=http://172.16.2.4:35770

# 浏览器 E2E 勿配置 VUE_APP_OPEN_PARTNER_GATEWAY_URL（留空走同源 /oauth/token 反代）
# 仅 curl 展示可配：VUE_APP_OPEN_PARTNER_PUBLIC_BASE_URL=http://172.16.2.4:35770
